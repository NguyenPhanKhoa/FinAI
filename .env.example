# FinGPT Finance Agent — Environment Variables
# Copy this file to .env and fill in your keys
# NOTE: No HuggingFace API key needed — model runs locally via Ollama!

# NewsAPI key — for fetching financial news headlines (free tier: 100 req/day)
# Get it at: https://newsapi.org/register
NEWSAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Finnhub API key — for real-time stock data and company news (free tier available)
# Get it at: https://finnhub.io/register
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
